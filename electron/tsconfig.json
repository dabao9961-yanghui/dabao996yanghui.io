{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "moduleResolution": "node",
    "outDir": "../dist-electron",
    "rootDir": ".",
    "baseUrl": "..",
    "paths": {
      "electron": ["node_modules/electron"]
    },
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "typeRoots": ["../node_modules/@types"]
  },
  "include": ["main.ts", "preload.ts"]
}
