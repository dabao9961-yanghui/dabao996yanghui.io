{
  "name": "gongyouji",
  "productName": "工友记",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "electron:dev": "vite --port=3000",
    "electron:build": "vite build && node build-electron.js && electron-builder",
    "electron:prebuild": "vite build && node build-electron.js"
  },
  "dependencies": {},
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "firebase": "^12.10.0",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-easy-crop": "^5.5.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.gongyouji.app",
    "productName": "工友记",
    "npmRebuild": false,
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!node_modules"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "标.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "标.ico",
      "category": "business"
    },
    "linux": {
      "target": "AppImage",
      "icon": "标.ico"
    }
  },
